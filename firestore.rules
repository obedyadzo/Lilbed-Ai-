rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened security primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validator blueprints
    function isValidUser(user) {
      return user.uid == request.auth.uid 
        && user.email is string 
        && user.email.size() <= 256;
    }

    function isValidProject(project) {
      return project.userId == request.auth.uid
        && project.id is string
        && project.id.size() <= 128
        && project.topic is string
        && project.topic.size() <= 1000
        && (project.depth == 'quick' || project.depth == 'deep')
        && project.messages is list
        && project.messages.size() <= 200
        && project.createdAt is string
        && project.createdAt.size() <= 64;
    }

    // User Accounts Isolation Path
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().email == existing().email;
      allow delete: if false; // profiles are immortal
    }

    // Research Projects Isolation Path
    match /projects/{projectId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isSignedIn() && isValidId(projectId) && isValidProject(incoming()) && incoming().userId == existing().userId && incoming().id == existing().id;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
